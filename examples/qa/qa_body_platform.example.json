    },
    "parametric_body_contract_c1": {
      "severity": "hard",
      "lane_class": "environment_or_contract",
      "mode": "command",
      "group": "body",
      "workspace_ref": "main",
      "requires_workspace_keys": ["paths.body_morphology_source_root"],
      "prerequisite_lane_ids": ["modular_morphology_inventory_c0"],
      "report_gate_id": "parametric_body_contract_c1",
      "signature_paths": ["status", "counts"],
      "command": ["powershell", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${repo_root}\\run_parametric_body_contract_c1.ps1", "-WorkspaceConfig", "${workspace}"]
    },
    "canonical_fusion_fixture_c2": {
